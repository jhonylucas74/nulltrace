{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "nulltrace-admin",
  "version": "0.1.0",
  "identifier": "app.nulltrace.admin",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1421",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "removeUnusedCommands": false
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Nulltrace Admin",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self'",
        "script-src": "'self'",
        "connect-src": "ipc: http://ipc.localhost http://127.0.0.1:50051 http://127.0.0.1:7675",
        "font-src": "'self' https://fonts.gstatic.com",
        "img-src": "'self' asset: data: blob:",
        "style-src": "'unsafe-inline' 'self' https://fonts.googleapis.com"
      }
    }
  },
  "bundle": {
    "active": true,
    "icon": ["icons/icon.png"],
    "resources": [],
    "externalBin": [],
    "copyright": "",
    "category": "DeveloperTool",
    "shortDescription": "Nulltrace Admin - Cluster management dashboard",
    "longDescription": "Admin dashboard for Nulltrace cluster: VMs, resources, network topology."
  }
}
